# Server
DIGITAL_LIFE_HOST=127.0.0.1
DIGITAL_LIFE_PORT=8788
DIGITAL_LIFE_RUNTIME_DIR=runtime
DIGITAL_LIFE_DB_PATH=runtime/digital-life.db
DIGITAL_LIFE_AUTOSTART=1
DIGITAL_LIFE_LOOP_MS=30000

# Optional OpenAI-compatible chat model
