# DIGITAL_LIFE_MODEL=deepseek-v4-flash
# DIGITAL_LIFE_MODEL_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# Optional speech and presence adapters
# XFYUN_TTS_ENABLED=0
# XFYUN_TTS_MODE=long_text
# XFYUN_APP_ID=
# XFYUN_API_KEY=
# XFYUN_API_SECRET=
